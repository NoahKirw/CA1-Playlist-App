  <p><strong>App Name:</strong> {{info.appName}}</p>
  <p><strong>Version:</strong> {{info.version}}</p>
  <p><strong>Total Playlists:</strong> {{info.playlists}}</p>
  <p><strong>Total Songs:</strong> {{info.songs}}</p>

</div>

<div class="ui segment">
  <h3>Location</h3>
  <img src="map.png" class="map-image">   
</div>

